flowchart LR
%% External systems
    WeatherAPI[(External Weather API)]
    IrrigationHw[(Irrigation Controller / Adapter)]
    DB[(PostgreSQL)]

%% Modules (as subgraphs)
    subgraph Agent["Module: Agent"]
        AgentSvc[IrrigationExecutionAgent]
    end

    subgraph Advisory["Module: Advisory"]
        AdvSvc[Advisory Service]
        AdvRepo[(R2DBC Repository)]
    end

    subgraph WeatherForecast["Module: WeatherForecast"]
        WfSvc[Weather Forecast Service]
        WfRepo[(R2DBC Repository)]
        WfClient[WeatherForecastClient]
    end

    subgraph RainHistory["Module: RainHistory"]
        RhSvc[Rain History Service]
        RhRepo[(R2DBC Repository)]
        RhClient[RainHistoryClient]
    end

    subgraph Irrigation["Module: Irrigation"]
        IrrSvc[Irrigation Service]
        IrrRepo[(R2DBC Repository)]
        IrrHw[HardwareIrrigationAdapter]
    end

    subgraph Dashboard["Module: Dashboard"]
        DashCtrl[Dashboard Controller]
        DashApi[Dashboard API Controller]
    end

%% Agent triggers
    AgentSvc -->|calculateAndProposeAdvice| AdvSvc
    AgentSvc -->|startIrrigation| IrrSvc

%% Advisory calls via Ports
    AdvSvc -->|WeatherForecastPort| WfSvc
    AdvSvc -->|RainHistoryPort| RhSvc
    AdvSvc -->|IrrigationPort| IrrSvc
    AdvSvc -->|saves| AdvRepo
    AdvRepo --> DB

%% WeatherForecast internals
    WfSvc -->|reads/writes| WfRepo
    WfSvc -->|fetches| WfClient
    WfRepo --> DB
    WfClient --> WeatherAPI

%% RainHistory internals
    RhSvc -->|reads/writes| RhRepo
    RhSvc -->|fetches| RhClient
    RhRepo --> DB
    RhClient --> WeatherAPI

%% Irrigation internals
    IrrSvc -->|saves| IrrRepo
    IrrSvc -->|triggers| IrrHw
    IrrRepo --> DB
    IrrHw --> IrrigationHw

%% Dashboard
    DashCtrl -->|AdvisoryPort| AdvSvc
    DashCtrl -->|IrrigationPort| IrrSvc
    DashApi -->|reads data| AdvSvc
    DashApi -->|reads data| WfSvc
    DashApi -->|reads data| RhSvc
    DashApi -->|reads data| IrrSvc
